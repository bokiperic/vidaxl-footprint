# Database
POSTGRES_USER=vidaxl
POSTGRES_PASSWORD=vidaxl
POSTGRES_DB=vidaxl_footprint
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Claude API (optional — mock mode if not set)
ANTHROPIC_API_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO

# Bedrock (AWS deployment)
USE_BEDROCK=false
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=eu.anthropic.claude-3-haiku-20240307-v1:0

# Auth - set these to enable login gate (required in production)
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=

# API key for programmatic access (required in production)
API_KEY=
